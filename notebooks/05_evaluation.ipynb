{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 05 — Evaluación, Wilcoxon-Bonferroni y Tabla 4.3\n",
    "\n",
    "**TFM RunnAing**\n",
    "\n",
    "- Métricas: MAE, RMSE, R², MAPE, Pearson r\n",
    "- Comparación estadística: Wilcoxon signed-rank test con corrección Bonferroni\n",
    "- Referencia: Demšar (2006)\n",
    "- Genera: outputs/tables/tabla_4_3_modelos.csv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "from src.evaluation import wilcoxon_bonferroni, build_results_table\n",
    "\n",
    "PROCESSED = Path('../data/processed')\n",
    "TABLES = Path('../outputs/tables')\n",
    "TABLES.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print('Setup OK')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar resultados del notebook 04\n",
    "with open(PROCESSED / 'all_metrics.pkl', 'rb') as f:\n",
    "    all_metrics = pickle.load(f)\n",
    "with open(PROCESSED / 'all_errors.pkl', 'rb') as f:\n",
    "    all_errors = pickle.load(f)\n",
    "\n",
    "print('Modelos evaluados:', list(all_metrics.keys()))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test de Wilcoxon signed-rank pareado con corrección de Bonferroni\n",
    "wilcoxon_df = wilcoxon_bonferroni(all_errors, reference_model='LinearRegression')\n",
    "print('Resultados Wilcoxon-Bonferroni:')\n",
    "print(wilcoxon_df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tabla 4.3: métricas + p-valor vs. baseline\n",
    "tabla_4_3 = build_results_table(all_metrics, wilcoxon_df, reference_model='LinearRegression')\n",
    "\n",
    "# Mostrar columnas principales\n",
    "cols_show = ['MAE_mean', 'MAE_std', 'RMSE_mean', 'R2_mean', 'MAPE_mean',\n",
    "             'Pearson_r_mean', 'p_bonferroni_vs_baseline']\n",
    "print('\\nTabla 4.3 — Resultados por modelo:')\n",
    "print(tabla_4_3[cols_show].round(4).to_string())\n",
    "\n",
    "tabla_4_3.to_csv(TABLES / 'tabla_4_3_modelos.csv')\n",
    "print('\\nTabla 4.3 guardada en outputs/tables/tabla_4_3_modelos.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ranking de modelos por MAE\n",
    "ranking = tabla_4_3['MAE_mean'].sort_values()\n",
    "print('\\nRanking por MAE (menor es mejor):')\n",
    "for rank, (model, mae) in enumerate(ranking.items(), 1):\n",
    "    print(f'  {rank}. {model}: MAE={mae:.4f}')"
   ]
  }
 ],
