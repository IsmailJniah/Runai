{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 07 — Análisis ACWR (Gabbett, 2016) y Tabla 4.4\n",
    "\n",
    "**TFM RunnAing**\n",
    "\n",
    "- ACWR = carga_aguda_7d / carga_crónica_28d\n",
    "- Cohorte apta: usuarios con span temporal ≥ 28 días\n",
    "- Zonas Gabbett: < 0.80 / 0.80–1.30 / 1.30–1.50 / > 1.50\n",
    "- Genera: outputs/tables/tabla_4_4_acwr_cohorte.csv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "from src.acwr import (\n",
    "    filter_eligible_users,\n",
    "    compute_acwr_all_users,\n",
    "    zone_distribution,\n",
    ")\n",
    "\n",
    "np.random.seed(42)\n",
    "PROCESSED = Path('../data/processed')\n",
    "TABLES = Path('../outputs/tables')\n",
    "FIGURES = Path('../outputs/figures')\n",
    "TABLES.mkdir(parents=True, exist_ok=True)\n",
    "FIGURES.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print('Setup OK')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar dataset procesado con TRIMP y fechas\n",
    "df = pd.read_pickle(PROCESSED / 'df_processed.pkl')\n",
    "y = pd.read_pickle(PROCESSED / 'y.pkl')  # TRIMP alineado\n",
    "\n",
    "# Unir TRIMP al dataframe\n",
    "df['trimp'] = y\n",
    "df = df[df['trimp'].notna()].copy()\n",
    "\n",
    "n_total_users = df['userId'].nunique()\n",
    "n_total_sessions = len(df)\n",
    "print(f'Total: {n_total_sessions:,} sesiones, {n_total_users:,} usuarios')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Filtrar cohorte apta para ACWR (span >= 28 días)\n",
    "df_eligible, span_stats = filter_eligible_users(df, date_col='date', user_col='userId',\n",
    "                                                 min_span_days=28)\n",
    "\n",
    "n_elig_users = df_eligible['userId'].nunique()\n",
    "n_elig_sessions = len(df_eligible)\n",
    "pct_users = 100 * n_elig_users / n_total_users\n",
    "pct_sessions = 100 * n_elig_sessions / n_total_sessions\n",
    "\n",
    "print(f'Cohorte apta (span >= 28d):')\n",
    "print(f'  Usuarios: {n_elig_users:,} ({pct_users:.1f}% del total)')\n",
    "print(f'  Sesiones: {n_elig_sessions:,} ({pct_sessions:.1f}% del total)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular ACWR diario para todos los usuarios de la cohorte\n",
    "print('Calculando ACWR (puede tardar unos minutos)...')\n",
    "acwr_df = compute_acwr_all_users(df_eligible, date_col='date', trimp_col='trimp', user_col='userId')\n",
    "print(f'Registros ACWR generados: {len(acwr_df):,}')\n",
    "print(acwr_df[['trimp_acute', 'trimp_chronic', 'acwr']].describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribución por zonas Gabbett\n",
    "acwr_valid = acwr_df[acwr_df['acwr'].notna()]\n",
    "dist = zone_distribution(acwr_valid)\n",
    "print('\\nDistribución por zonas Gabbett:')\n",
    "print(dist.to_string(index=False))\n",
    "\n",
    "# Tabla 4.4\n",
    "tabla_4_4 = pd.DataFrame({\n",
    "    'n_total_usuarios': [n_total_users],\n",
    "    'n_cohorte_apta': [n_elig_users],\n",
    "    'pct_cohorte_apta': [round(pct_users, 1)],\n",
    "    'n_sesiones_total': [n_total_sessions],\n",
    "    'n_sesiones_cohorte': [n_elig_sessions],\n",
    "    'pct_sesiones_cohorte': [round(pct_sessions, 1)],\n",
    "})\n",
    "\n",
    "# Añadir distribución de zonas\n",
    "for _, row in dist.iterrows():\n",
    "    tabla_4_4[f'zone_{row[\"zone\"]}_n'] = row['n']\n",
    "    tabla_4_4[f'zone_{row[\"zone\"]}_pct'] = round(row['pct'], 1)\n",
    "\n",
    "tabla_4_4.to_csv(TABLES / 'tabla_4_4_acwr_cohorte.csv', index=False)\n",
    "print('\\nTabla 4.4 guardada.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualización distribución ACWR\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "acwr_valid['acwr'].clip(0, 3).hist(bins=60, ax=axes[0], color='steelblue', edgecolor='white')\n",
    "axes[0].axvline(0.80, color='orange', linestyle='--', label='0.80 (límite bajo)')\n",
    "axes[0].axvline(1.30, color='green', linestyle='--', label='1.30 (límite óptimo)')\n",
    "axes[0].axvline(1.50, color='red', linestyle='--', label='1.50 (límite riesgo)')\n",
    "axes[0].set_title('Distribución ACWR')\n",
    "axes[0].set_xlabel('ACWR')\n",
    "axes[0].legend(fontsize=8)\n",
    "\n",
    "colors = {'insuficiente': '#3182bd', 'optima': '#31a354', 'precaucion': '#fd8d3c', 'riesgo': '#de2d26', 'sin_dato': '#bdbdbd'}\n",
    "zone_colors = [colors.get(z, 'gray') for z in dist['zone']]\n",
    "dist.set_index('zone')['pct'].plot(kind='bar', ax=axes[1], color=zone_colors, edgecolor='white')\n",
    "axes[1].set_title('% por zona Gabbett')\n",
    "axes[1].set_xlabel('Zona')\n",
    "axes[1].set_ylabel('%')\n",
    "axes[1].tick_params(axis='x', rotation=30)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES / 'acwr_distribution.png', dpi=120, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Figura ACWR guardada.')"
   ]
  }
 ],
