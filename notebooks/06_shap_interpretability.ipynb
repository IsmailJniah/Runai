{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 06 — Interpretabilidad SHAP (Figura 4.1)\n",
    "\n",
    "**TFM RunnAing**\n",
    "\n",
    "- TreeExplainer sobre el mejor modelo entrenado\n",
    "- Summary plot beeswarm → Figura 4.1\n",
    "- Bar plot global de importancia media |SHAP|\n",
    "- Waterfall de un caso concreto\n",
    "- Top-5 features por importancia SHAP\n",
    "\n",
    "Referencia: Lundberg & Lee (2017)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "from src.shap_utils import (\n",
    "    compute_shap_values,\n",
    "    plot_shap_beeswarm,\n",
    "    plot_shap_bar,\n",
    "    plot_shap_waterfall,\n",
    "    top_features_by_shap,\n",
    ")\n",
    "\n",
    "np.random.seed(42)\n",
    "PROCESSED = Path('../data/processed')\n",
    "FIGURES = Path('../outputs/figures')\n",
    "FIGURES.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print('Setup OK')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar mejor modelo y features\n",
    "with open('../outputs/models/best_model.pkl', 'rb') as f:\n",
    "    model_bundle = pickle.load(f)\n",
    "\n",
    "best_model = model_bundle['model']\n",
    "best_model_name = model_bundle['model_name']\n",
    "feature_names = model_bundle['feature_names']\n",
    "\n",
    "X = pd.read_pickle(PROCESSED / 'X.pkl')\n",
    "print(f'Mejor modelo: {best_model_name}')\n",
    "print(f'Muestras para SHAP: {len(X):,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular valores SHAP (muestra representativa para eficiencia)\n",
    "# Si el dataset es grande, usamos un subsample para el plot\n",
    "SHAP_SAMPLE = min(5000, len(X))\n",
    "X_shap = X.sample(SHAP_SAMPLE, random_state=42)\n",
    "\n",
    "print(f'Calculando SHAP values sobre {SHAP_SAMPLE} sesiones...')\n",
    "shap_values = compute_shap_values(best_model, X_shap)\n",
    "print('SHAP values calculados.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Figura 4.1 — Summary plot beeswarm\n",
    "beeswarm_path = plot_shap_beeswarm(\n",
    "    shap_values, X_shap,\n",
    "    max_display=9,  # 9 features = todas\n",
    "    save_path=FIGURES / 'figura_4_1_shap_beeswarm.png'\n",
    ")\n",
    "print(f'Figura 4.1 guardada: {beeswarm_path}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Bar plot global\n",
    "bar_path = plot_shap_bar(shap_values, save_path=FIGURES / 'shap_bar_global.png')\n",
    "print(f'Bar plot guardado: {bar_path}')\n",
    "\n",
    "# Waterfall de un caso concreto (primera sesión de la muestra)\n",
    "wf_path = plot_shap_waterfall(shap_values, sample_idx=0,\n",
    "                              save_path=FIGURES / 'shap_waterfall_sample0.png')\n",
    "print(f'Waterfall guardado: {wf_path}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top-5 features por importancia SHAP global\n",
    "top5 = top_features_by_shap(shap_values, feature_names=feature_names, n=5)\n",
    "print('Top-5 features por importancia SHAP global:')\n",
    "print(top5.to_string(index=False))"
   ]
  }
 ],
