 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 — Feature Engineering (9 features externas, sin FC)\n",
    "\n",
    "**TFM RunnAing**\n",
    "\n",
    "Construye las 9 variables de entrada desde los datos GPS:\n",
    "1. duration_min — duración (min)\n",
    "2. distance_km — distancia (km, Haversine)\n",
    "3. speed_mean — velocidad media (km/h)\n",
    "4. speed_std — std velocidad instantánea\n",
    "5. pace_mean — ritmo medio (min/km)\n",
    "6. elevation_gain — desnivel positivo acumulado (m)\n",
    "7. elevation_loss — desnivel negativo acumulado (m)\n",
    "8. altitude_mean — altitud media (m)\n",
    "9. grade_factor — desnivel / distancia\n",
    "\n",
    "**ASSERT al final: FC no aparece en X**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "from src.features import build_feature_matrix, FEATURE_NAMES, assert_no_hr_leakage\n",
    "\n",
    "np.random.seed(42)\n",
    "PROCESSED = Path('../data/processed')\n",
    "\n",
    "print(f'Features a construir ({len(FEATURE_NAMES)}): {FEATURE_NAMES}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar dataset preprocesado (sin FC)\n",
    "df = pd.read_pickle(PROCESSED / 'df_processed.pkl')\n",
    "print(f'Sesiones cargadas: {len(df):,}')\n",
    "print(f'Columnas: {list(df.columns)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Construir matriz de features desde series GPS\n",
    "print('Calculando features (puede tardar varios minutos)...')\n",
    "X = build_feature_matrix(df)\n",
    "print(f'Matriz X: {X.shape}')\n",
    "print(X.describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ASSERT CRÍTICO: FC no puede estar en X\n",
    "assert_no_hr_leakage(X)\n",
    "print('PASS — Ninguna columna de FC detectada en X.')\n",
    "\n",
    "# Valores nulos\n",
    "null_pct = X.isnull().mean() * 100\n",
    "print('\\n% valores nulos por feature:')\n",
    "print(null_pct.to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Eliminar filas con NaN en X o en y (trimp)\n",
    "y = df['trimp']\n",
    "groups = df['userId']\n",
    "dates = df['date']\n",
    "\n",
    "valid_mask = X.notna().all(axis=1) & y.notna()\n",
    "X = X[valid_mask]\n",
    "y = y[valid_mask]\n",
    "groups = groups[valid_mask]\n",
    "dates = dates[valid_mask]\n",
    "\n",
    "print(f'Sesiones válidas tras eliminar NaN: {len(X):,}')\n",
    "print(f'Usuarios únicos: {groups.nunique():,}')\n",
    "\n",
    "# Guardar X, y, groups para notebook de modelado\n",
    "X.to_pickle(PROCESSED / 'X.pkl')\n",
    "y.to_pickle(PROCESSED / 'y.pkl')\n",
    "groups.to_pickle(PROCESSED / 'groups.pkl')\n",
    "dates.to_pickle(PROCESSED / 'dates.pkl')\n",
    "print('Features guardadas en data/processed/')"
   ]
  }
 ],
