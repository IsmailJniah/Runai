{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 — Entrenamiento de Modelos + Optuna + GroupKFold\n",
    "\n",
    "**TFM RunnAing**\n",
    "\n",
    "- Validación: GroupKFold (k=5) por user_id — sin leakage\n",
    "- Optimización: Optuna (50 trials por modelo, TPE sampler, seed=42)\n",
    "- Modelos: LinearRegression (baseline), RandomForest, GradientBoosting, XGBoost, LightGBM\n",
    "- random_state=42 en todo punto estocástico"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "from src.splits import get_group_kfold_splits, fold_stats\n",
    "from src.models import get_model, MODEL_REGISTRY\n",
    "from src.tuning import tune_all_models\n",
    "from src.evaluation import evaluate_model_cv\n",
    "\n",
    "np.random.seed(42)\n",
    "PROCESSED = Path('../data/processed')\n",
    "MODELS_OUT = Path('../outputs/models')\n",
    "MODELS_OUT.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print('Setup OK')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar features, target y grupos\n",
    "X = pd.read_pickle(PROCESSED / 'X.pkl')\n",
    "y = pd.read_pickle(PROCESSED / 'y.pkl')\n",
    "groups = pd.read_pickle(PROCESSED / 'groups.pkl')\n",
    "\n",
    "print(f'X: {X.shape}, y: {y.shape}')\n",
    "print(f'Usuarios únicos: {groups.nunique()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generar splits GroupKFold (k=5)\n",
    "splits = get_group_kfold_splits(X, y, groups, n_splits=5)\n",
    "print('Estadísticas de los folds:')\n",
    "print(fold_stats(splits, groups).to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Optimización de hiperparámetros con Optuna (50 trials por modelo)\n",
    "# NOTA: este paso puede tardar 30-90 minutos dependiendo del hardware\n",
    "print('Iniciando optimización Optuna (50 trials × 5 modelos)...')\n",
    "best_params = tune_all_models(X, y, groups, n_trials=50, seed=42)\n",
    "\n",
    "for model_name, result in best_params.items():\n",
    "    print(f'{model_name}: MAE_cv={result[\"best_mae\"]:.4f} | params={result[\"best_params\"]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluar cada modelo con los mejores hiperparámetros en GroupKFold\n",
    "all_metrics = {}\n",
    "all_errors = {}\n",
    "\n",
    "for model_name, result in best_params.items():\n",
    "    print(f'Evaluando {model_name}...')\n",
    "    model = get_model(model_name, **result['best_params'])\n",
    "    agg_metrics, fold_errors = evaluate_model_cv(model, X, y, splits)\n",
    "    all_metrics[model_name] = agg_metrics\n",
    "    all_errors[model_name] = fold_errors\n",
    "    print(f'  MAE={agg_metrics[\"MAE_mean\"]:.4f} ± {agg_metrics[\"MAE_std\"]:.4f} | '\n",
    "          f'R2={agg_metrics[\"R2_mean\"]:.4f}')\n",
    "\n",
    "# Guardar resultados intermedios\n",
    "with open(PROCESSED / 'all_metrics.pkl', 'wb') as f:\n",
    "    pickle.dump(all_metrics, f)\n",
    "with open(PROCESSED / 'all_errors.pkl', 'wb') as f:\n",
    "    pickle.dump(all_errors, f)\n",
    "with open(PROCESSED / 'best_params.pkl', 'wb') as f:\n",
    "    pickle.dump(best_params, f)\n",
    "\n",
    "print('Resultados guardados.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Entrenar el mejor modelo sobre todos los datos (para SHAP y producción)\n",
    "best_model_name = min(all_metrics, key=lambda m: all_metrics[m]['MAE_mean'])\n",
    "print(f'Mejor modelo: {best_model_name}')\n",
    "\n",
    "best_model = get_model(best_model_name, **best_params[best_model_name]['best_params'])\n",
    "best_model.fit(X, y)\n",
    "\n",
    "with open(MODELS_OUT / 'best_model.pkl', 'wb') as f:\n",
    "    pickle.dump({'model': best_model, 'model_name': best_model_name,\n",
    "                 'feature_names': list(X.columns)}, f)\n",
    "print(f'Modelo guardado en outputs/models/best_model.pkl')"
   ]
  }
 ],
